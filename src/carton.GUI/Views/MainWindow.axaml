<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:carton.ViewModels"
        xmlns:views="using:carton.Views.Pages"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:carton.GUI.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
        x:Class="carton.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="vm:MainViewModel"
        Title="{DynamicResource App.Name}"
        Width="900" Height="640"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="None">

  <Window.Styles>
    <Style Selector="Button.connectionToggle">
      <Setter Property="MinWidth" Value="56"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>
  </Window.Styles>

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
      <Grid Margin="12,8">
        <TextBlock Grid.Column="0"
                   Text="{Binding DashboardViewModel.CurrentProfile}"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="13"
                   TextTrimming="CharacterEllipsis"
                   MaxLines="1"
                   MaxWidth="220"
                   ToolTip.Tip="{Binding DashboardViewModel.CurrentProfile}"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        <TextBlock
                   Text="{Binding CurrentPage.Title}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="Medium"/>
      </Grid>
    </Border>

    <SplitView Grid.Row="1"
               IsPaneOpen="{Binding IsPaneOpen}"
               DisplayMode="Inline"
               OpenPaneLength="200"
               CompactPaneLength="200">
      <SplitView.Pane>
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0"
                        Margin="0,28,0,24"
                        HorizontalAlignment="Center"
                        Spacing="12"
                        Width="168">
              <Image Width="52"
                     Height="52"
                     Source="/Assets/carton_icon.png"/>
              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          HorizontalAlignment="Center"
                          Margin="-10,0,0,0">
                <Ellipse Width="10"
                         Height="10"
                         Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusConverter}}"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ConnectionStatus}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
              </StackPanel>

              <Button Command="{Binding DashboardViewModel.ToggleConnectionCommand}"
                      Classes="accent connectionToggle"
                      HorizontalAlignment="Center"
                      IsEnabled="{Binding DashboardViewModel.CanToggleConnection}"
                      ToolTip.Tip="{Binding DashboardViewModel.StatusText}">
                <Button.Transitions>
                  <Transitions>
                    <DoubleTransition Property="MinWidth" Duration="0:0:0.2"/>
                  </Transitions>
                </Button.Transitions>
                <Grid>
                  <Grid Width="56"
                        Height="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsVisible="{Binding !DashboardViewModel.IsConnected}">
                    <Path Width="10"
                          Height="12"
                          Data="M0,0 L10,6 L0,12 Z"
                          Fill="#F8FFFFFF"
                          Stretch="Fill"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="2,0,0,0"/>
                  </Grid>

                  <StackPanel Orientation="Horizontal"
                              Spacing="0"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              IsVisible="{Binding DashboardViewModel.IsConnected}">
                    <Grid Width="40"
                          Height="40">
                      <Grid Width="12"
                            Height="12"
                            ColumnDefinitions="*,*"
                            ColumnSpacing="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding DashboardViewModel.IsConnected}">
                        <Border Grid.Column="0"
                                Background="#F8FFFFFF"
                                CornerRadius="1"/>
                        <Border Grid.Column="1"
                                Background="#F8FFFFFF"
                                CornerRadius="1"/>
                      </Grid>
                    </Grid>
                    <Border Width="1"
                            Height="16"
                            Margin="0,12,0,12"
                            Background="#33FFFFFF"
                            IsVisible="{Binding DashboardViewModel.IsConnected}"/>
                     <Grid Margin="10,0,12,0"
                           VerticalAlignment="Center"
                           IsVisible="{Binding DashboardViewModel.IsConnected}">
                       <TextBlock Text="{Binding DashboardViewModel.SessionStartTimeMeasureText}"
                                  Opacity="0"
                                  TextAlignment="Center"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  IsHitTestVisible="False"/>
                       <TextBlock Text="{Binding DashboardViewModel.SessionStartTimeText}"
                                  TextAlignment="Center"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  FontFeatures="tnum"
                                  IsHitTestVisible="False"/>
                     </Grid>
                    </StackPanel>
                  </Grid>
                </Button>
            </StackPanel>

            <Grid Grid.Row="1"
                  Margin="6,4,0,12"
                  ColumnDefinitions="8,*">
              <Canvas Grid.Column="0"
                      Width="8"
                      IsHitTestVisible="False">
                <Border Width="3"
                        Height="18"
                        Background="{DynamicResource SystemAccentColor}"
                        CornerRadius="2"
                        HorizontalAlignment="Left"
                        Margin="{Binding NavigationIndicatorOffset, Converter={StaticResource NavigationIndicatorMarginConverter}}">
                  <Border.Transitions>
                    <Transitions>
                      <ThicknessTransition Property="Margin" Duration="0:0:0.18"/>
                    </Transitions>
                  </Border.Transitions>
                </Border>
              </Canvas>

              <ListBox Grid.Column="1"
                       Classes="navPane"
                       ItemsSource="{Binding NavigationPages}"
                       SelectedItem="{Binding SelectedPage}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:NavigationPage">
                    <Grid ColumnDefinitions="20,*"
                          ColumnSpacing="12"
                          VerticalAlignment="Center">
                      <PathIcon Grid.Column="0"
                                Width="18"
                                Height="18"
                                Data="{Binding Converter={StaticResource NavigationIconConverter}}"
                                Foreground="{Binding $parent[ListBoxItem].Foreground}"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Converter={StaticResource NavigationTitleConverter}}"
                                 VerticalAlignment="Center"
                                 Foreground="{Binding $parent[ListBoxItem].Foreground}"/>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Grid>
        </Border>
      </SplitView.Pane>

      <Grid>
        <views:DashboardView DataContext="{Binding DashboardViewModel}"
                             IsVisible="{Binding #MainWindowRoot.DataContext.IsDashboardPage}"/>
        <views:GroupsView DataContext="{Binding ActiveGroupsViewModel}"
                          IsVisible="{Binding #MainWindowRoot.DataContext.IsGroupsPage}"/>
        <ContentControl Content="{Binding ActiveTransientPage}"
                        IsVisible="{Binding #MainWindowRoot.DataContext.IsTransientPage}"/>
        <Grid IsHitTestVisible="False">
          <ItemsControl ItemsSource="{Binding #MainWindowRoot.DataContext.Toasts}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,24">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="10"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:ToastNotificationViewModel">
                <Border Classes="toast"
                        MaxWidth="440"
                        Opacity="{Binding Opacity}"
                        Margin="{Binding OffsetMargin}">
                  <Border.Transitions>
                    <Transitions>
                      <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
                      <ThicknessTransition Property="Margin" Duration="0:0:0.22"/>
                    </Transitions>
                  </Border.Transitions>
                  <TextBlock Text="{Binding Message}"
                             TextWrapping="Wrap"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Grid>
    </SplitView>

    <ContentControl Grid.Row="0"
                    Grid.RowSpan="2"
                    Content="{Binding KernelDialogHost}">
      <ContentControl.ContentTemplate>
        <DataTemplate DataType="vm:MainViewModel">
          <Grid Background="#80000000">
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="400"
                    MaxWidth="560">
              <StackPanel Spacing="16">
                  <TextBlock Text="{DynamicResource MainWindow.KernelDialog.Title}" FontSize="18" FontWeight="SemiBold"/>
                  <TextBlock TextWrapping="Wrap">
                    <Run Text="{DynamicResource MainWindow.KernelDialog.DescriptionLine1}"/>
                    <LineBreak/>
                    <Run Text="{DynamicResource MainWindow.KernelDialog.LatestVersionPrefix}"/>
                    <Run Text="{Binding LatestVersion}" FontWeight="Medium"/>
                  </TextBlock>

                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource Settings.Kernel.Mirror}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding KernelDownloadMirrors}"
                              SelectedItem="{Binding SelectedKernelDownloadMirror}"
                              MinWidth="150"
                              IsEnabled="{Binding !IsDownloadingKernel}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Converter={StaticResource KernelDownloadMirrorDisplayConverter}}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </Grid>

                  <ProgressBar IsIndeterminate="False"
                               Value="{Binding DownloadProgress}"
                               Maximum="100"
                               IsVisible="{Binding IsDownloadingKernel}"
                               Height="4"/>

                  <TextBlock Text="{Binding DownloadStatus}"
                             TextWrapping="Wrap"
                             FontSize="12"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="{Binding KernelPrimaryActionText}"
                            Command="{Binding DownloadKernelCommand}"
                            Classes="accent"
                            IsEnabled="{Binding !IsDownloadingKernel}"/>
                    <Button Content="{DynamicResource MainWindow.KernelDialog.Button.Later}"
                            Command="{Binding CloseKernelDialogCommand}"
                            IsEnabled="{Binding !IsDownloadingKernel}"/>
                  </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </DataTemplate>
      </ContentControl.ContentTemplate>
    </ContentControl>
  </Grid>

</Window>
